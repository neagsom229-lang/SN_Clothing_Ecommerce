# Copy this file to ".env" (same folder as package.json) and fill in your values.

# The backend API (see /backend) — default matches "npm run dev" in backend/.
VITE_API_URL=http://localhost:5000/api

# Stripe TEST MODE publishable key (starts with pk_test_).
# Get it from https://dashboard.stripe.com/test/apikeys — same place you got
# the secret key for backend/.env. This one is safe to expose in the browser.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
