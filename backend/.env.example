# Copy this file to ".env" and fill in your own values.
# Never commit the real ".env" file.

# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Stripe (TEST MODE keys only — they start with sk_test_ / pk_test_)
# Get them free from https://dashboard.stripe.com/test/apikeys after creating
# a Stripe account. Test mode never touches real money.
STRIPE_SECRET_KEY=sk_test_...
# Only needed if you wire up the webhook endpoint with the Stripe CLI:
STRIPE_WEBHOOK_SECRET=whsec_...
